{
  "name": "swarmbot",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build -w @swarmbot/api && npm run build -w web",
    "dev:api": "npm run dev -w @swarmbot/api",
    "dev:web": "npm run start -w web",
    "test": "npm run test -w @swarmbot/api",
    "lint": "npm run lint -w @swarmbot/api"
  },
  "engines": {
    "node": ">=20"
  }
}
