{
    "name": "@swarmbot/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsx watch --env-file=.env.development src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc -p tsconfig.json --noEmit && eslint src"
    },
    "dependencies": {
        "@apollo/server": "^5.5.1",
        "@as-integrations/express5": "^1.1.2",
        "@graphql-tools/schema": "^10.0.16",
        "@kubernetes/client-node": "^1.4.0",
        "better-sqlite3": "^12.11.1",
        "body-parser": "^1.20.3",
        "cors": "^2.8.5",
        "dockerode": "^5.0.1",
        "express": "^5.2.1",
        "graphql": "^16.10.0",
        "graphql-subscriptions": "^2.0.0",
        "graphql-ws": "^5.16.2",
        "js-yaml": "^4.1.0",
        "jsonwebtoken": "^9.0.2",
        "kysely": "^0.29.3",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "ws": "^8.20.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/body-parser": "^1.19.5",
        "@types/cors": "^2.8.17",
        "@types/dockerode": "^4.0.1",
        "@types/express": "^5.0.6",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^24.0.0",
        "@types/pg": "^8.20.0",
        "@types/ws": "^8.5.13",
        "@vitest/coverage-v8": "^4.1.6",
        "eslint": "^10.6.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.62.1",
        "vitest": "^4.1.6"
    }
}
