{
    "name": "@swarmboty/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsx watch --env-file=.env.development src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@apollo/server": "^5.5.1",
        "@as-integrations/express4": "^1.1.2",
        "@graphql-tools/schema": "^10.0.16",
        "body-parser": "^1.20.3",
        "cors": "^2.8.5",
        "dockerode": "^4.0.4",
        "express": "^4.21.2",
        "graphql": "^16.10.0",
        "graphql-subscriptions": "^2.0.0",
        "graphql-ws": "^5.16.2",
        "js-yaml": "^4.1.0",
        "jsonwebtoken": "^9.0.2",
        "nano": "^10.1.4",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.5",
        "@types/cors": "^2.8.17",
        "@types/dockerode": "^4.0.1",
        "@types/express": "^4.17.21",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^24.0.0",
        "@types/ws": "^8.5.13",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "@vitest/coverage-v8": "^4.1.6",
        "vitest": "^4.1.6"
    }
